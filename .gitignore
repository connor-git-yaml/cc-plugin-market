# Dependencies
# 不加尾斜杠：同时匹配目录和 symlink（worktree 机制用 symlink 指向父仓库 node_modules）
node_modules

# Build output
dist/
build/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Environment
.env*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript cache
*.tsbuildinfo

# Generated output (managed by reverse-spec)
drift-logs/

# MCP server config (动态生成 by SC-002/SC-004 driver eval harness)
.mcp.json

# Spectra batch checkpoint (动态生成 by spectra batch / prepare)
specs/.spectra-checkpoint.json

# Driver eval raw run JSON (F170d host 实测产物；含 LLM 随机性，不入库；只 track verification-report.md)
specs/*/verification/sc-002-driver-eval-*.json

# Checkpoint files
specs/.reverse-spec-checkpoint.json
.claude/settings.local.json
.claude/scheduled_tasks.lock
CLAUDE.local.md

# Spec Driver 本地缓存与运行态
.specify/.spec-driver-path
.specify/runs/

# Feature 152 — spectra index UnifiedGraph snapshot（按 worktree 各自独立）
.spectra/
.specify/scorecards/
.specify/templates/
.agents
.agents/

# Worktree 本地态（由 sync-worktree-local-state.sh 管理，绝对路径符号链接，机器相关）
_reference

# Claude Code worktree 自动管理目录（运行态，机器相关）
.claude/worktrees/
.claire/

# Spectra batch dogfood 临时产物（顶层 spec 文件如 src.spec.md / plugins.spec.md 仍 tracked）
specs/README.md
specs/_meta/
specs/modules/
specs/project/
specs/bundles/

# E2E fixture 运行时泄漏（panoramic pipeline 偶尔创建相对路径 var/folders/... 输出，
# 与 mkdtempSync 临时目录一同清理；该模式由 Feature 144/146 测试触发，本质是 pipeline 兼容问题）
tests/fixtures/e2e/*/var/

# Feature 143 baseline workspaces（运行时 clone 大型开源项目的 scratch 目录，不入库）
tests/baseline/.workspaces/*
!tests/baseline/.workspaces/.gitkeep

# 测评结果 / 数据不入库（2026-05-05 清理 9.3 MB 测评产物）
# 入库的只有 perf anchor: tests/baseline/<project>/<tool>/full.json (~100 KB 总量)
# 不入库的：
# - truth-set.json (Feature 150: 外部代码 hono/HikariCP/GORM 等的 AST 抽取结果，每次跑生成)
# - tasks/ (Feature 147: task fixture，每次评估生成，含 LLM 单次随机性，git track 反成噪声)
# - repeats/ (Feature 149: N=5 重测原始 fixture，每次跑生成)
# - competitive-evaluation-report-auto.md (auto-report，每次重生成)
tests/baseline/**/truth-set.json
tests/baseline/repeats/
tests/baseline/tasks/
specs/147-competitor-evaluation-platform/competitive-evaluation-report-auto.md

# Feature 157 SWE-Bench Lite eval runs（不入库；fixtures/ 入库作为评测基础数据）
tests/baseline/swe-bench-lite/runs/

# Feature 176 SWE-Bench Verified 横向对比：整树都是可再生评测产物，全部不入库
# （事实源是 specs/176/.../preregistration.md 记录的 task id + 筛选规则 + seed，fixture 重生）
tests/baseline/swe-bench-verified/

# Python bytecode（Feature 176 引入 Verified importer 后 py_compile 会产生）
__pycache__/
*.pyc

# Feature 147 aider repomap 副作用产物（aider --show-repo-map 在 cwd 创建）
.aider.chat.history.md
.aider.tags.cache.v*
.aider.input.history

# F187 评测设施 v2：Python venv + patch 持久化产物不入库
scripts/.swebench-venv/
run_artifacts/

# F206 校准/验证 harness 运行产物（calibrated-pool / sets / validation 结果，不入库）
# 只入库：specs/206-.../calibration-runbook.md（manual）+ split sets anchor（taskSetHash）
.calibration-output/

# F190 demo fixture 原始第三方文档（Hono/ECharts）— 只提交构建产物 kb/ + FIXTURE.md，原文按 FIXTURE.md URL 可重建
plugins/demo-kb-*/source-docs/
specs/190-scaffold-kb-mvp/trace.md
