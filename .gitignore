# Dependencies
# 不加尾斜杠：同时匹配目录和 symlink（worktree 机制用 symlink 指向父仓库 node_modules）
node_modules

# Build output
dist/
build/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Environment
.env*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# TypeScript cache
*.tsbuildinfo

# Generated output (managed by reverse-spec)
drift-logs/

# Checkpoint files
specs/.reverse-spec-checkpoint.json
.claude/settings.local.json
CLAUDE.local.md

# Spec Driver 本地缓存与运行态
.specify/.spec-driver-path
.specify/runs/
.specify/scorecards/
.specify/templates/
.agents
.agents/

# Worktree 本地态（由 sync-worktree-local-state.sh 管理，绝对路径符号链接，机器相关）
_reference

# Claude Code worktree 自动管理目录（运行态，机器相关）
.claude/worktrees/
.claire/

# Spectra batch dogfood 临时产物（顶层 spec 文件如 src.spec.md / plugins.spec.md 仍 tracked）
specs/README.md
specs/_meta/
specs/modules/
specs/project/
specs/bundles/

# E2E fixture 运行时泄漏（panoramic pipeline 偶尔创建相对路径 var/folders/... 输出，
# 与 mkdtempSync 临时目录一同清理；该模式由 Feature 144/146 测试触发，本质是 pipeline 兼容问题）
tests/fixtures/e2e/*/var/
