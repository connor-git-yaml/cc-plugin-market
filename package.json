{
  "name": "spectra-cli",
  "version": "4.1.1",
  "description": "通过 AST 静态分析 + LLM 混合流水线，将源代码逆向工程为结构化 Spec 文档的多语言代码分析平台",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "spectra": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "grammars/",
    "queries/",
    "scripts/lifecycle-runner.cjs",
    "plugins/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "prebuild": "tsx scripts/inline-d3.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "lint": "tsc --noEmit",
    "docs:sync:agents": "node scripts/sync-agent-docs.mjs",
    "repo:sync": "node scripts/repo-sync.mjs",
    "repo:check": "node scripts/repo-check.mjs",
    "release:sync": "node scripts/sync-release-contracts.mjs",
    "release:check": "node scripts/validate-release-contracts.mjs",
    "hooks:install": "bash scripts/install-hooks.sh",
    "hooks:check": "bash scripts/check-plugin-sync.sh",
    "worktree:sync-local-state": "bash scripts/sync-worktree-local-state.sh",
    "spec-driver:check:wrappers": "node plugins/spec-driver/scripts/validate-wrapper-sources.mjs --project-root . --json",
    "spectra:sync:skills": "node plugins/spectra/scripts/sync-skill-mirrors.mjs --project-root . --json",
    "spectra:check:skills": "node plugins/spectra/scripts/validate-skill-sources.mjs --project-root . --json",
    "codex:spec-driver:install": "bash plugins/spec-driver/scripts/codex-skills.sh install",
    "codex:spec-driver:install:global": "bash plugins/spec-driver/scripts/codex-skills.sh install --global",
    "codex:spec-driver:remove": "bash plugins/spec-driver/scripts/codex-skills.sh remove",
    "codex:spec-driver:remove:global": "bash plugins/spec-driver/scripts/codex-skills.sh remove --global",
    "postinstall": "node scripts/lifecycle-runner.cjs postinstall",
    "preuninstall": "node scripts/lifecycle-runner.cjs preuninstall"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "chokidar": "^4.0.3",
    "dependency-cruiser": "^16.8.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-types": "^0.24.8",
    "handlebars": "^4.7.8",
    "p-limit": "^6.1.0",
    "ts-morph": "^24.0.0",
    "web-tree-sitter": "^0.24.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.0.4",
    "d3-force": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.x"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
